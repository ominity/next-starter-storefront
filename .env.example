# -----------------------------------------------------------------------------
# Core mode
# -----------------------------------------------------------------------------
# true  -> use built-in mock content (works out of the box)
# false -> use live Ominity API client
OMINITY_USE_MOCK_DATA=true

# -----------------------------------------------------------------------------
# Ominity API (required when OMINITY_USE_MOCK_DATA=false)
# -----------------------------------------------------------------------------
OMINITY_API_URL=https://demo.ominity.com/api
OMINITY_API_KEY=
OMINITY_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Auth (OAuth password grant)
# -----------------------------------------------------------------------------
# Required in live mode when OMINITY_FEATURE_AUTH=true
OMINITY_AUTH_CLIENT_ID=
OMINITY_AUTH_CLIENT_SECRET=
OMINITY_AUTH_SCOPE=
OMINITY_AUTH_SESSION_SECRET=change-me-with-32-plus-characters

# Cookie settings for auth + cart server APIs
OMINITY_AUTH_COOKIE_NAME=ominity_auth_session
OMINITY_AUTH_COOKIE_MAX_AGE_SECONDS=2592000
OMINITY_CART_COOKIE_NAME=ominity_cart_id
OMINITY_CART_COOKIE_MAX_AGE_SECONDS=2592000

# -----------------------------------------------------------------------------
# Commerce module feature flags
# -----------------------------------------------------------------------------
# Set OMINITY_FEATURE_COMMERCE=false to disable all commerce routes.
OMINITY_FEATURE_COMMERCE=true
OMINITY_FEATURE_COMMERCE_PRODUCTS=true
OMINITY_FEATURE_COMMERCE_CATEGORIES=true

# Modular commerce routes (disable per project if not needed)
OMINITY_FEATURE_CART=true
OMINITY_FEATURE_WISHLIST=true
OMINITY_FEATURE_CHECKOUT=true
OMINITY_FEATURE_PAYMENT=true
# When true, checkout allows guest mode (email + address without login)
OMINITY_CHECKOUT_ALLOW_GUEST=true

# -----------------------------------------------------------------------------
# Auth module feature flags
# -----------------------------------------------------------------------------
OMINITY_FEATURE_AUTH=true

# Max records scanned by starter commerce data source in live mode
OMINITY_COMMERCE_LIST_LIMIT=250

# -----------------------------------------------------------------------------
# Routing / locales
# -----------------------------------------------------------------------------
# Default locale data is resolved from the channel configuration
# (languages/countries/default language/default country).
OMINITY_DEFAULT_LOCALE=en
# options: none | language | country-language
OMINITY_LOCALE_SEGMENT_STRATEGY=language
# options: if-not-canonical | never
OMINITY_CANONICAL_REDIRECT_POLICY=if-not-canonical
# options: localize-relative | passthrough
OMINITY_STRING_LINK_STRATEGY=localize-relative
# optional locale-aware home redirect for `/`
# options: off | accept-language | cookie-accept-language | geo-cookie-accept-language
OMINITY_HOME_LOCALE_REDIRECT_MODE=off
# locale cookie checked when using cookie-based modes
OMINITY_HOME_LOCALE_REDIRECT_COOKIE_NAME=ominity_locale
# skip redirect for bots/crawlers (recommended for SEO)
OMINITY_HOME_LOCALE_REDIRECT_SKIP_BOTS=true
OMINITY_TRAILING_SLASH=false
OMINITY_BASE_PATH=

# -----------------------------------------------------------------------------
# Site behavior
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
OMINITY_REVALIDATE_SECONDS=300
OMINITY_DEBUG_LOGS=false
OMINITY_DEBUG_BAR=true
OMINITY_STRICT_COMPONENTS=true

# -----------------------------------------------------------------------------
# Preview / draft mode
# -----------------------------------------------------------------------------
OMINITY_DRAFT_TOKEN=change-me

# -----------------------------------------------------------------------------
# Forms (optional)
# -----------------------------------------------------------------------------
# reCAPTCHA public settings are delivered via the Forms API (recaptcha field options).
# Backend-only: configure reCAPTCHA secrets/settings in the Ominity CMS app.
# Validate incoming form IDs via @ominity/api-module-forms before forwarding
OMINITY_FORMS_VALIDATE_FORM_ID=true
